<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 🔽 תוכן גלילה -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/bottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:orientation="vertical"
            android:padding="24dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- 🔥 תמונת פרופיל -->
            <ImageView
                android:id="@+id/profileImage"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_launcher_background"
                android:background="@drawable/circle_bg"
                android:padding="4dp"/>

            <!-- 🔥 כפתור העלאה -->
            <Button
                android:id="@+id/uploadImageBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Upload Image"
                android:layout_marginTop="8dp"/>

            <!-- 🔥 שם -->
            <EditText
                android:id="@+id/nameText"
                android:hint="Name"
                android:enabled="false"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <!-- 🔥 גיל -->
            <EditText
                android:id="@+id/ageText"
                android:hint="Age"
                android:enabled="false"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <!-- 🔥 מגדר -->
            <EditText
                android:id="@+id/genderText"
                android:hint="Gender"
                android:enabled="false"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <!-- 🔗 Instagram -->
            <TextView
                android:id="@+id/instagramText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#0000EE"
                android:clickable="true"/>

            <EditText
                android:id="@+id/instagramEdit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Instagram link"
                android:visibility="gone"/>

            <!-- 🔗 Facebook -->
            <TextView
                android:id="@+id/facebookText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#0000EE"
                android:clickable="true"/>

            <EditText
                android:id="@+id/facebookEdit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Facebook link"
                android:visibility="gone"/>

            <!-- 🔗 LinkedIn -->
            <TextView
                android:id="@+id/linkedinText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#0000EE"
                android:clickable="true"/>

            <EditText
                android:id="@+id/linkedinEdit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="LinkedIn link"
                android:visibility="gone"/>

            <!-- 🔗 Twitter -->
            <TextView
                android:id="@+id/twitterText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#0000EE"
                android:clickable="true"/>

            <EditText
                android:id="@+id/twitterEdit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Twitter link"
                android:visibility="gone"/>

            <!-- כפתורים -->
            <Button
                android:id="@+id/editBtn"
                android:text="Edit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <Button
                android:id="@+id/saveBtn"
                android:text="Save Changes"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

        </LinearLayout>
    </ScrollView>

    <!-- 🔥 Bottom Bar -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:background="#EEEEEE"
        android:weightSum="4"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnSettings"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:text="Settings"/>

        <Button
            android:id="@+id/btnNearby"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:text="Nearby"/>

        <Button
            android:id="@+id/btnLogout"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:text="Logout"/>

        <Button
            android:id="@+id/btnProfile"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:text="Profile"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>