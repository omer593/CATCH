<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/catch_bg">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <ImageView
                android:id="@+id/profileImage"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_gravity="center"
                android:layout_marginBottom="12dp"
                android:background="@drawable/circle_bg"
                android:clipToOutline="true"
                android:scaleType="centerCrop" />
            <LinearLayout
                android:id="@+id/profileInfoCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/user_card_bg"
                android:visibility="gone">

                <TextView
                    android:id="@+id/profileNameView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="@color/catch_text"
                    android:gravity="center"/>

                <TextView
                    android:id="@+id/profileAgeView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:textColor="@color/catch_text"
                    android:gravity="center"
                    android:layout_marginTop="8dp"/>

                <TextView
                    android:id="@+id/profileGenderView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:textColor="@color/catch_text"
                    android:gravity="center"
                    android:layout_marginTop="4dp"/>

            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/uploadImageBtn"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="20dp"
                android:text="Upload Image"
                android:textAllCaps="false"
                android:textColor="@color/catch_link" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="Name">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/nameText"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/catch_text" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="Age">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/ageText"
                    android:textSize="18sp"
                    android:gravity="center"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:textColor="@color/catch_text" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:hint="Gender">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/genderText"
                    android:textSize="18sp"
                    android:gravity="center"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/catch_text" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Social Links -->
        <!-- Social Links -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Social Links"
            android:textColor="@color/catch_link"
            android:textStyle="bold"
            android:textSize="16sp"
            android:gravity="center"
            android:textAlignment="center"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="12dp"/>
            <EditText
                android:id="@+id/instagramEdit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Instagram"
                android:visibility="gone"
                android:textColor="@color/catch_text"
                android:textColorHint="@color/catch_hint"
                android:background="@android:color/transparent"/>
        <LinearLayout
            android:id="@+id/instagramRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/user_card_bg">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_instagram"/>

            <TextView
                android:id="@+id/instagramText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="Instagram"
                android:textColor="@color/catch_text"
                android:textSize="16sp"/>

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_share"/>
        </LinearLayout>
            <EditText
                android:id="@+id/instagramEdit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Instagram URL"
                android:textColor="@color/catch_text"
                android:textColorHint="@color/catch_hint"
                android:visibility="gone"
                android:background="@drawable/edit_text_bg"
                android:padding="12dp"/>

            <EditText
                android:id="@+id/facebookEdit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Facebook"
                android:visibility="gone"
                android:textColor="@color/catch_text"
                android:textColorHint="@color/catch_hint"/>
        <LinearLayout
            android:id="@+id/facebookRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/user_card_bg">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_facebook"/>

            <TextView
                android:id="@+id/facebookText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="Facebook"
                android:textColor="@color/catch_text"
                android:textSize="16sp"/>

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_share"/>
        </LinearLayout>
            <EditText
                android:id="@+id/facebookEdit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Facebook URL"
                android:textColor="@color/catch_text"
                android:textColorHint="@color/catch_hint"
                android:visibility="gone"
                android:background="@drawable/edit_text_bg"
                android:padding="12dp"/>

            <EditText
                android:id="@+id/linkedinEdit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="LinkedIn"
                android:visibility="gone"
                android:textColor="@color/catch_text"
                android:textColorHint="@color/catch_hint"/>
        <LinearLayout
            android:id="@+id/linkedinRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/user_card_bg">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_linkedin"/>

            <TextView
                android:id="@+id/linkedinText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="LinkedIn"
                android:textColor="@color/catch_text"
                android:textSize="16sp"/>

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_share"/>
        </LinearLayout>
            <EditText
                android:id="@+id/linkedinEdit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="LinkedIn URL"
                android:textColor="@color/catch_text"
                android:textColorHint="@color/catch_hint"
                android:visibility="gone"
                android:background="@drawable/edit_text_bg"
                android:padding="12dp"/>
            <EditText
                android:id="@+id/twitterEdit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Twitter"
                android:visibility="gone"
                android:textColor="@color/catch_text"
                android:textColorHint="@color/catch_hint"/>
        <LinearLayout
            android:id="@+id/twitterRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/user_card_bg">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_twitter"/>

            <TextView
                android:id="@+id/twitterText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="Twitter"
                android:textColor="@color/catch_text"
                android:textSize="16sp"/>

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_share"/>
        </LinearLayout>
            <EditText
                android:id="@+id/twitterEdit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Twitter URL"
                android:textColor="@color/catch_text"
                android:textColorHint="@color/catch_hint"
                android:visibility="gone"
                android:background="@drawable/edit_text_bg"
                android:padding="12dp"/>


            <com.google.android.material.button.MaterialButton
                android:id="@+id/editBtn"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="8dp"
                android:text="Edit Profile"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="@android:color/transparent"
                app:strokeColor="@color/catch_purple"
                app:strokeWidth="2dp"
                app:cornerRadius="18dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/saveBtn"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="8dp"
                android:text="Save Changes"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="@android:color/transparent"
                android:visibility="gone"
                app:strokeColor="@color/catch_purple"
                app:strokeWidth="2dp"
                app:cornerRadius="18dp"/>

        </LinearLayout>
    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/catch_surface"
        app:itemIconTint="@color/bottom_nav_color"
        app:itemTextColor="@color/bottom_nav_color"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:menu="@menu/bottom_nav_menu" />
</androidx.constraintlayout.widget.ConstraintLayout>